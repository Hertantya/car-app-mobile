{
  "expo": {
    "name": "Car App",
    "slug": "car-app-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.carapp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.carapp.mobile"
    },
    "scheme": "car-app",
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
